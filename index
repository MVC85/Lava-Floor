<script>
// ============================================================
//  ⏱️  CONFIGURAÇÃO DE TEMPOS  ← AJUSTE AQUI!
// ============================================================
const TEMPO = {
  CONTAGEM:  5,        // segundos antes do furacão começar
  FURACAO:   30,        // segundos de furacão
  AVISO_EM:  20,        // segundo do furacão em que aparece o aviso do vulcão
  LAVA:      3 * 60,    // segundos com lava na tela  (5 min = 5 * 60)
  GELO:      1 * 30,    // segundos congelando        (5 min = 5 * 60)
};

function openOptions() {
  document.getElementById('opt-contagem').value = TEMPO.CONTAGEM;
  document.getElementById('opt-furacao').value  = TEMPO.FURACAO;
  document.getElementById('opt-aviso').value    = TEMPO.AVISO_EM;
  document.getElementById('opt-lava').value     = TEMPO.LAVA / 60;
  document.getElementById('opt-gelo').value     = TEMPO.GELO / 60;
  document.getElementById('options-modal').classList.add('open');
}

function saveOptions() {
  const contagem = Math.max(3,  parseInt(document.getElementById('opt-contagem').value) || 10);
  const furacao  = Math.max(5,  parseInt(document.getElementById('opt-furacao').value)  || 30);
  let   aviso    = Math.max(3,  parseInt(document.getElementById('opt-aviso').value)    || 20);
  const lava     = Math.max(1,  parseInt(document.getElementById('opt-lava').value)     || 5);
  const gelo     = Math.max(1,  parseInt(document.getElementById('opt-gelo').value)     || 5);

  // Aviso não pode ser maior que a duração do furacão - 3s
  aviso = Math.min(aviso, furacao - 3);

  TEMPO.CONTAGEM = contagem;
  TEMPO.FURACAO  = furacao;
  TEMPO.AVISO_EM = aviso;
  TEMPO.LAVA     = lava * 60;
  TEMPO.GELO     = gelo * 60;

  document.getElementById('options-modal').classList.remove('open');
}
// ============================================================
//  VOZES (arquivos locais)
// ============================================================
const VOZES = {
  se_preparem:      'se_preparem.mp3',
  ventania_espalhem:'ventania_espalhem.mp3',
  chao_lava:        'chao_lava.mp3',
  lava_esfriando:   'lava_esfriando.mp3',
};

let vozAtual = null;

function playVoz(nome) {
  if (vozAtual) { vozAtual.pause(); vozAtual = null; }
  const src = VOZES[nome];
  if (!src) return;
  const audio = new Audio(src);
  audio.volume = 1;
  audio.play().catch(() => {});
  vozAtual = audio;
}

// ============================================================
//  ÁUDIOS LOCAIS
// ============================================================
const audioLocal = { explosao: null, lava: null, freezing: null };
let lavaAudioEl = null;
let freezingAudioEl = null;

// Tenta carregar automaticamente os arquivos da mesma pasta
function tentarCarregarAutomatico() {
  const arquivos = [
    { tipo: 'explosao', nome: 'explosion.mp3' },
    { tipo: 'lava',     nome: 'lava_loop.mp3' },
    { tipo: 'freezing', nome: 'freezing_loop.mp3' },
  ];
  arquivos.forEach(({ tipo, nome }) => {
    const audio = new Audio(nome);
    audio.addEventListener('canplaythrough', () => {
      audioLocal[tipo] = nome;
      const nomeEl = document.getElementById('nome-' + tipo);
      if (nomeEl) { nomeEl.textContent = '✅ ' + nome; nomeEl.classList.add('loaded'); }
    }, { once: true });
    audio.load();
  });
}

function carregarAudio(input, tipo) {
  const file = input.files[0];
  if (!file) return;
  const url = URL.createObjectURL(file);
  audioLocal[tipo] = url;
  const nomeEl = document.getElementById('nome-' + tipo);
  nomeEl.textContent = '✅ ' + file.name;
  nomeEl.classList.add('loaded');
}

function playExplosaoLocal() {
  if (audioLocal.explosao) {
    const el = new Audio(audioLocal.explosao);
    el.volume = 1;
    el.play().catch(() => {});
    return true;
  }
  return false;
}

function startLavaAudioLocal() {
  stopLavaAudioLocal();
  if (!audioLocal.lava) return false;
  lavaAudioEl = new Audio(audioLocal.lava);
  lavaAudioEl.loop = true;
  lavaAudioEl.volume = 0;
  lavaAudioEl.play().catch(() => {});
  // Fade in
  let v = 0;
  const fade = setInterval(() => {
    v = Math.min(v + 0.05, 1);
    if (lavaAudioEl) lavaAudioEl.volume = v;
    if (v >= 1) clearInterval(fade);
  }, 100);
  return true;
}

function stopLavaAudioLocal(fadeTime = 2000) {
  if (!lavaAudioEl) return;
  const el = lavaAudioEl;
  lavaAudioEl = null;
  let v = el.volume;
  const step = v / (fadeTime / 100);
  const fade = setInterval(() => {
    v = Math.max(0, v - step);
    el.volume = v;
    if (v <= 0) { clearInterval(fade); el.pause(); }
  }, 100);
}

function startFreezingAudio() {
  stopFreezingAudio();
  if (!audioLocal.freezing) return;
  freezingAudioEl = new Audio(audioLocal.freezing);
  freezingAudioEl.loop = true;
  freezingAudioEl.volume = 0;
  freezingAudioEl.play().catch(() => {});
  let v = 0;
  const fade = setInterval(() => {
    v = Math.min(v + 0.05, 1);
    if (freezingAudioEl) freezingAudioEl.volume = v;
    if (v >= 1) clearInterval(fade);
  }, 100);
}

function stopFreezingAudio(fadeTime = 2000) {
  if (!freezingAudioEl) return;
  const el = freezingAudioEl;
  freezingAudioEl = null;
  let v = el.volume;
  const step = v / (fadeTime / 100);
  const fade = setInterval(() => {
    v = Math.max(0, v - step);
    el.volume = v;
    if (v <= 0) { clearInterval(fade); el.pause(); }
  }, 100);
}

// ============================================================
//  AUDIO ENGINE (Web Audio API - no external files needed)
// ============================================================
const AudioCtx = window.AudioContext || window.webkitAudioContext;
let ctx;

function getCtx() {
  if (!ctx) ctx = new AudioCtx();
  if (ctx.state === 'suspended') ctx.resume();
  return ctx;
}

// White noise wind
let windNodes = null;
function startWind(volume = 0.4) {
  stopWind();
  const ac = getCtx();
  const bufferSize = ac.sampleRate * 3;
  const buffer = ac.createBuffer(1, bufferSize, ac.sampleRate);
  const data = buffer.getChannelData(0);
  for (let i = 0; i < bufferSize; i++) data[i] = Math.random() * 2 - 1;

  const source = ac.createBufferSource();
  source.buffer = buffer;
  source.loop = true;

  // Bandpass for wind texture
  const bp1 = ac.createBiquadFilter();
  bp1.type = 'bandpass';
  bp1.frequency.value = 600;
  bp1.Q.value = 0.5;

  const bp2 = ac.createBiquadFilter();
  bp2.type = 'bandpass';
  bp2.frequency.value = 1200;
  bp2.Q.value = 0.3;

  const gain = ac.createGain();
  gain.gain.setValueAtTime(0, ac.currentTime);
  gain.gain.linearRampToValueAtTime(volume, ac.currentTime + 1.5);

  // Tremolo (wind gusting)
  const lfo = ac.createOscillator();
  lfo.frequency.value = 0.4;
  const lfoGain = ac.createGain();
  lfoGain.gain.value = 0.2;
  lfo.connect(lfoGain);
  lfoGain.connect(gain.gain);
  lfo.start();

  source.connect(bp1);
  bp1.connect(bp2);
  bp2.connect(gain);
  gain.connect(ac.destination);
  source.start();

  windNodes = { source, gain, lfo };
}

function stopWind(fadeTime = 1.5) {
  if (!windNodes) return;
  const { gain, source, lfo } = windNodes;
  gain.gain.linearRampToValueAtTime(0, getCtx().currentTime + fadeTime);
  setTimeout(() => { try { source.stop(); lfo.stop(); } catch(e){} }, fadeTime * 1000 + 100);
  windNodes = null;
}

// Explosion sound
function playExplosion() {
  // Use local file if loaded, otherwise generate
  if (playExplosaoLocal()) return;

  const ac = getCtx();
  const bufSize = ac.sampleRate * 2;
  const buf = ac.createBuffer(1, bufSize, ac.sampleRate);
  const d = buf.getChannelData(0);
  for (let i = 0; i < bufSize; i++) d[i] = (Math.random() * 2 - 1) * Math.exp(-i / (ac.sampleRate * 0.3));

  const src = ac.createBufferSource();
  src.buffer = buf;

  const lp = ac.createBiquadFilter();
  lp.type = 'lowpass';
  lp.frequency.value = 300;

  const g = ac.createGain();
  g.gain.setValueAtTime(3.5, ac.currentTime);
  g.gain.exponentialRampToValueAtTime(0.001, ac.currentTime + 2);

  // Rumble oscillator
  const osc = ac.createOscillator();
  osc.type = 'sawtooth';
  osc.frequency.setValueAtTime(80, ac.currentTime);
  osc.frequency.exponentialRampToValueAtTime(20, ac.currentTime + 1.5);
  const og = ac.createGain();
  og.gain.setValueAtTime(1.5, ac.currentTime);
  og.gain.exponentialRampToValueAtTime(0.001, ac.currentTime + 1.5);

  src.connect(lp); lp.connect(g); g.connect(ac.destination);
  osc.connect(og); og.connect(ac.destination);
  src.start(); osc.start(); osc.stop(ac.currentTime + 2);
}

// Lava bubbling
let bubbleInterval = null;
function startLavaBubble() {
  // Start local audio loop if available (runs alongside or instead of bubbles)
  const hasLocal = startLavaAudioLocal();

  // Always keep the synthetic bubbles as texture (less frequent if local audio playing)
  const bubbleMs = () => (hasLocal ? 1400 : 600) + Math.random() * 800;
  bubbleInterval = setInterval(() => {
    const ac = getCtx();
    const osc = ac.createOscillator();
    osc.type = 'sine';
    const baseFreq = 60 + Math.random() * 80;
    osc.frequency.setValueAtTime(baseFreq, ac.currentTime);
    osc.frequency.exponentialRampToValueAtTime(baseFreq * 2.5, ac.currentTime + 0.08);
    osc.frequency.exponentialRampToValueAtTime(baseFreq * 0.5, ac.currentTime + 0.25);
    const g = ac.createGain();
    g.gain.setValueAtTime(hasLocal ? 0.1 : 0.25, ac.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001, ac.currentTime + 0.3);
    osc.connect(g); g.connect(ac.destination);
    osc.start(); osc.stop(ac.currentTime + 0.35);
  }, bubbleMs());
}
function stopLavaBubble() {
  clearInterval(bubbleInterval);
  bubbleInterval = null;
  stopLavaAudioLocal();
}

// Freeze/cracking ice sound
function playFreeze() {
  const ac = getCtx();
  for (let i = 0; i < 8; i++) {
    setTimeout(() => {
      const src = ac.createBufferSource();
      const bufSize = ac.sampleRate * 0.3;
      const buf = ac.createBuffer(1, bufSize, ac.sampleRate);
      const d = buf.getChannelData(0);
      for (let j = 0; j < bufSize; j++) d[j] = (Math.random()*2-1) * Math.exp(-j/(ac.sampleRate*0.05));
      src.buffer = buf;
      const hp = ac.createBiquadFilter(); hp.type='highpass'; hp.frequency.value=2000;
      const g = ac.createGain(); g.gain.value = 0.6;
      src.connect(hp); hp.connect(g); g.connect(ac.destination);
      src.start();
    }, i * 400 + Math.random() * 300);
  }
}

