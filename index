// ============================================================
//  MAIN GAME SEQUENCE
// ============================================================
let gameLoop = null;

function startGame() {
  $('start-screen').style.display = 'none';
  getCtx(); // Unlock audio
  buildStars();
  playVoz('se_preparem');
  runCycle();
}

function runCycle() {
  // Reset all layers
  resetLayers();
  doCountdown(TEMPO.CONTAGEM, () => doHurricane());
}

function resetLayers() {
  // Reset lava
  const ll = $('lava-layer');
  ll.style.transition = 'none';
  ll.style.height = '0';

  // Reset ice
  $('ice-layer').style.opacity = '0';
  $('ice-overlay').className = '';

  // Reset lava overlay
  $('lava-overlay').style.background = 'rgba(180,20,0,0)';

  // Reset hurricane
  $('hurricane-layer').classList.remove('active');

  // Reset volcano
  $('volcano-layer').classList.remove('show');

  // Reset warning
  $('warning-msg').style.opacity = '0';
  $('warning-msg').classList.remove('show');

  // Reset glow
  $('lava-glow').classList.remove('active');

  // Reset timer bar
  $('timer-bar').style.transform = 'scaleX(1)';
  $('timer-bar').className = '';
  $('timer-bar').style.transition = 'none';

  // Reset bg
  $('bg').style.background = 'radial-gradient(ellipse at 50% 80%, #1a0a2e 0%, #0d0520 100%)';
}

function doCountdown(seconds, callback) {
  setPhase('🎮 Preparar!');
  const cd = $('countdown');
  const num = $('countdown-number');
  const label = $('countdown-label');
  cd.classList.remove('hidden');
  cd.style.opacity = '1';
  label.textContent = 'Espalhem os objetos!';
  let s = seconds;
  num.textContent = s;
  num.style.animation = 'none'; void num.offsetWidth; num.style.animation = 'countPulse 1s ease-in-out';

  const tick = setInterval(() => {
    s--;
    num.textContent = s;
    num.style.animation = 'none'; void num.offsetWidth; num.style.animation = 'countPulse 1s ease-in-out';
    if (s <= 3 && s > 0) {
      num.style.color = '#ff4500';
    } else {
      num.style.color = '#fff';
    }
    if (s <= 0) {
      clearInterval(tick);
      cd.style.opacity = '0';
      setTimeout(() => cd.classList.add('hidden'), 600);
      callback();
    }
  }, 1000);
}

// ----- HURRICANE (30 seconds) -----
function doHurricane() {
  setPhase('🌀 Furacão!');
  buildHurricane();
  $('hurricane-layer').classList.add('active');
  startWind(0.5);

  setTimeout(() => playVoz('ventania_espalhem'), 500);

  // Animate bg
  $('bg').style.transition = 'background 2s';
  $('bg').style.background = 'radial-gradient(ellipse at 50% 50%, #1a2a3a 0%, #0a0d15 100%)';

  animateTimerBar(TEMPO.FURACAO * 1000);

  // Warning message at AVISO_EM seconds mark
  setTimeout(() => {
    doWarning();
  }, TEMPO.AVISO_EM * 1000);

  setTimeout(() => {
    stopWind();
    $('hurricane-layer').classList.remove('active');
    doVolcano();
  }, TEMPO.FURACAO * 1000);
}

// ----- WARNING MESSAGE -----
function doWarning() {
  setPhase('⚠️ Atenção!');
  const msg = $('warning-msg');
  msg.style.opacity = '1';
  msg.classList.add('show');
  $('bg').style.background = 'radial-gradient(ellipse at 50% 50%, #2a0a00 0%, #0d0520 100%)';

  // (aviso visual apenas — sem áudio separado para esta fase)

  setTimeout(() => {
    msg.style.transition = 'opacity 0.5s';
    msg.style.opacity = '0';
  }, 8000);
}

// ----- VOLCANO -----
function doVolcano() {
  // Garante que o aviso some imediatamente
  const msg = $('warning-msg');
  msg.style.transition = 'opacity 0.3s';
  msg.style.opacity = '0';
  msg.classList.remove('show');

  setPhase('🌋 Vulcão!');
  $('volcano-layer').classList.add('show');
  $('bg').style.background = 'radial-gradient(ellipse at 50% 80%, #3a0500 0%, #1a0000 100%)';

  // Shake effect
  let shakes = 0;
  const shakeApp = setInterval(() => {
    $('app').style.transform = `translate(${(Math.random()*12-6)}px, ${(Math.random()*6-3)}px)`;
    shakes++;
    if (shakes > 15) { clearInterval(shakeApp); $('app').style.transform = ''; }
  }, 80);

  setTimeout(() => {
    flashScreen('#ff8c00', 400);
    playExplosion();
    spawnEruptionParticles();
    setPhase('💥 Erupção!');
    setTimeout(() => {
      $('volcano-layer').classList.remove('show');
      doLava();
    }, 2000);
  }, 2000);
}

// ----- LAVA RISING (fills screen in ~8 seconds, stays 5 minutes) -----
function doLava() {
  setPhase('🔥 LAVA! Não toque no chão!');
  $('lava-glow').classList.add('active');
  startLavaBubble();

  setTimeout(() => playVoz('chao_lava'), 500);

  // Start rising
  raiseLava(110, 8000);

  // Screen reddening
  let redOpacity = 0;
  const redInterval = setInterval(() => {
    redOpacity = Math.min(redOpacity + 0.04, 0.35);
    $('lava-overlay').style.background = `rgba(180,20,0,${redOpacity})`;
    $('bg').style.background = `radial-gradient(ellipse at 50% 80%, #4a0000 0%, #200000 100%)`;
    if (redOpacity >= 0.35) clearInterval(redInterval);
  }, 300);

  const LAVA_DURATION = TEMPO.LAVA * 1000;
  animateTimerBar(LAVA_DURATION);

  setTimeout(() => {
    stopLavaBubble();
    doFreeze();
  }, LAVA_DURATION);
}

// ----- FREEZE (5 minutes) -----
function doFreeze() {
  setPhase('❄️ Congelando!');
  playFreeze();
  buildIceCracks();
  addSnowflakes();
  startFreezingAudio();

  setTimeout(() => playVoz('lava_esfriando'), 500);

  $('ice-layer').style.opacity = '1';
  setTimeout(() => $('ice-overlay').classList.add('freezing'), 100);

  $('bg').style.transition = 'background 4s';
  $('bg').style.background = 'radial-gradient(ellipse at 50% 50%, #002244 0%, #001122 100%)';

  // Lava slowly going down
  const ll = $('lava-layer');
  ll.style.transition = 'height 20s ease-in';
  ll.style.height = '0';

  $('lava-overlay').style.transition = 'background 8s';
  $('lava-overlay').style.background = 'rgba(0,60,120,0.25)';

  $('lava-glow').classList.remove('active');

  const FREEZE_DURATION = TEMPO.GELO * 1000;
  animateTimerBar(FREEZE_DURATION, true);

  setTimeout(() => {
    $('ice-layer').style.opacity = '0';
    $('ice-overlay').classList.remove('freezing');
    stopFreezingAudio();
    playVoz('se_preparem');
    runCycle();
  }, FREEZE_DURATION);
}

// ============================================================
//  WAKE LOCK – keep screen on while game is open
// ============================================================
let wakeLock = null;

async function requestWakeLock() {
  if (!('wakeLock' in navigator)) return;
  try {
    wakeLock = await navigator.wakeLock.request('screen');
  } catch (e) { /* silently ignore if denied */ }
}

// Re-acquire after tab becomes visible again (required by the spec)
document.addEventListener('visibilitychange', () => {
  if (document.visibilityState === 'visible') requestWakeLock();
});

// ============================================================
//  INIT
// ============================================================
buildStars();
requestWakeLock();
tentarCarregarAutomatico();
</script>
