<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🌋 Chão é Lava!</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@700;900&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Fredoka One', cursive;
    overflow: hidden;
    width: 100vw;
    height: 100vh;
    background: #1a0a2e;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ===== SCREEN LAYERS ===== */
  #app {
    position: relative;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
  }

  /* ===== BACKGROUND ===== */
  #bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 80%, #1a0a2e 0%, #0d0520 100%);
    transition: background 2s ease;
  }

  /* ===== STARS ===== */
  .stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .star {
    position: absolute;
    background: white;
    border-radius: 50%;
    animation: twinkle var(--d) infinite;
  }
  @keyframes twinkle {
    0%,100% { opacity: 0.2; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.3); }
  }

  /* floor/objects removed – kids use real objects! */

  /* ===== COUNTDOWN ===== */
  #countdown {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 100;
    opacity: 1;
    transition: opacity 1s;
  }
  #countdown-number {
    font-size: clamp(8rem, 25vw, 20rem);
    color: #fff;
    text-shadow: 0 0 40px #ff6b35, 0 0 80px #ff6b35;
    line-height: 1;
    animation: countPulse 1s ease-in-out;
  }
  @keyframes countPulse {
    0% { transform: scale(1.5); opacity: 0; }
    60% { transform: scale(0.95); }
    100% { transform: scale(1); opacity: 1; }
  }
  #countdown-label {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: clamp(1.2rem, 4vw, 2.5rem);
    color: #ffd700;
    text-transform: uppercase;
    letter-spacing: 4px;
    text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    margin-top: 1rem;
  }

  /* ===== HURRICANE ===== */
  #hurricane-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.5s;
    z-index: 50;
  }
  #hurricane-layer.active { opacity: 1; }

  .wind-line {
    position: absolute;
    height: 3px;
    background: linear-gradient(90deg, transparent, rgba(200,230,255,0.8), transparent);
    border-radius: 2px;
    animation: windMove var(--dur, 0.4s) linear infinite;
    animation-delay: var(--delay, 0s);
  }
  @keyframes windMove {
    0% { transform: translateX(-110vw) rotate(var(--angle, -5deg)); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateX(110vw) rotate(var(--angle, -5deg)); opacity: 0; }
  }

  /* Debris */
  .debris {
    position: absolute;
    font-size: clamp(1rem, 3vw, 2.5rem);
    animation: debrisMove var(--dur, 2s) linear infinite;
    animation-delay: var(--delay, 0s);
    opacity: 0.9;
  }
  @keyframes debrisMove {
    0% { transform: translateX(-120vw) translateY(0) rotate(0deg); opacity: 0; }
    5% { opacity: 1; }
    50% { transform: translateX(0vw) translateY(var(--vy, -50px)) rotate(180deg); opacity: 1; }
    95% { opacity: 1; }
    100% { transform: translateX(120vw) translateY(calc(var(--vy, -50px)*2)) rotate(360deg); opacity: 0; }
  }

  /* ===== WARNING MESSAGE ===== */
  #warning-msg {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    text-align: center;
    padding: 2rem;
  }
  #warning-msg.show {
    animation: warningAppear 0.5s forwards;
  }
  @keyframes warningAppear {
    0% { opacity: 0; transform: scale(0.5); }
    70% { transform: scale(1.05); }
    100% { opacity: 1; transform: scale(1); }
  }
  #warning-text {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: clamp(1.8rem, 6vw, 5rem);
    color: #fff;
    text-shadow: 0 0 20px #ff4500, 0 0 40px #ff4500, 0 4px 0 #8b0000;
    line-height: 1.2;
    animation: shake 0.3s infinite;
  }
  @keyframes shake {
    0%,100% { transform: translateX(0) rotate(-1deg); }
    25% { transform: translateX(-6px) rotate(1deg); }
    75% { transform: translateX(6px) rotate(-1deg); }
  }
  .warning-icon {
    font-size: clamp(3rem, 10vw, 8rem);
    animation: iconPulse 0.5s ease-in-out infinite;
    margin-bottom: 1rem;
  }
  @keyframes iconPulse {
    0%,100% { transform: scale(1); }
    50% { transform: scale(1.2); }
  }

  /* ===== VOLCANO ===== */
  #volcano-layer {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: clamp(200px, 50vw, 500px);
    z-index: 150;
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }
  #volcano-layer.show { opacity: 1; }

  .volcano-svg {
    width: 100%;
    height: auto;
  }

  /* Eruption particles */
  #eruption-particles {
    position: absolute;
    bottom: 60%;
    left: 50%;
    transform: translateX(-50%);
    width: 10px;
    height: 10px;
    pointer-events: none;
    z-index: 160;
  }
  .particle {
    position: absolute;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    animation: eruptParticle var(--dur, 1s) ease-out forwards;
    animation-delay: var(--delay, 0s);
    opacity: 0;
  }
  @keyframes eruptParticle {
    0% { transform: translate(0,0) scale(1); opacity: 1; }
    100% { transform: translate(var(--tx, 0), var(--ty, -200px)) scale(0.2); opacity: 0; }
  }

  /* ===== LAVA ===== */
  #lava-layer {
    position: absolute;
    bottom: -10px;
    left: 0;
    width: 100%;
    height: 0;
    z-index: 180;
    overflow: hidden;
    transition: none;
  }
  #lava-surface {
    position: absolute;
    top: -30px;
    left: -5%;
    width: 110%;
    height: 60px;
    background: #ff4500;
    border-radius: 50%;
    animation: lavaSurface 2s ease-in-out infinite;
  }
  @keyframes lavaSurface {
    0%,100% { transform: scaleY(1) translateX(0); }
    33% { transform: scaleY(1.15) translateX(2%); }
    66% { transform: scaleY(0.9) translateX(-2%); }
  }
  #lava-body {
    position: absolute;
    top: 20px;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, #ff4500 0%, #cc2200 30%, #880000 70%, #550000 100%);
  }

  /* Lava bubbles */
  .lava-bubble {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 35%, #ff8c00, #cc2200);
    animation: lavaBubble var(--dur, 2s) ease-in-out infinite;
    animation-delay: var(--delay, 0s);
    opacity: 0.8;
  }
  @keyframes lavaBubble {
    0% { transform: scale(0) translateY(0); opacity: 0; }
    40% { opacity: 0.9; }
    80% { transform: scale(1) translateY(-20px); opacity: 0.7; }
    100% { transform: scale(1.2) translateY(-30px); opacity: 0; }
  }

  /* Lava glow */
  #lava-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 170;
    opacity: 0;
    transition: opacity 1s;
    background: radial-gradient(ellipse at 50% 100%, rgba(255,69,0,0.4) 0%, transparent 70%);
  }
  #lava-glow.active { opacity: 1; }

  /* Lava screen overlay */
  #lava-overlay {
    position: absolute;
    inset: 0;
    z-index: 190;
    opacity: 0;
    pointer-events: none;
    background: rgba(180, 20, 0, 0.0);
    transition: opacity 1s;
  }

  /* ===== FREEZE / ICE ===== */
  #ice-layer {
    position: absolute;
    inset: 0;
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    transition: opacity 2s;
  }
  #ice-layer.active { opacity: 1; }

  .ice-crack {
    position: absolute;
    background: linear-gradient(var(--angle, 0deg), transparent 40%, rgba(150,220,255,0.6) 50%, transparent 60%);
    animation: iceCrackAppear 0.5s forwards;
    animation-delay: var(--delay, 0s);
    opacity: 0;
  }
  @keyframes iceCrackAppear {
    0% { opacity: 0; transform: scaleX(0); }
    100% { opacity: 1; transform: scaleX(1); }
  }

  #ice-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(100,200,255,0.0) 0%, rgba(180,230,255,0.0) 100%);
    transition: background 4s ease;
  }
  #ice-overlay.freezing {
    background: linear-gradient(135deg, rgba(100,200,255,0.35) 0%, rgba(200,240,255,0.5) 100%);
  }

  /* Snowflakes */
  .snowflake {
    position: absolute;
    color: rgba(200,240,255,0.9);
    font-size: var(--size, 1.5rem);
    animation: snowFall var(--dur, 4s) linear infinite;
    animation-delay: var(--delay, 0s);
    top: -50px;
    opacity: 0;
  }
  @keyframes snowFall {
    0% { transform: translateY(-50px) rotate(0deg); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 0.8; }
    100% { transform: translateY(110vh) rotate(360deg); opacity: 0; }
  }

  /* ===== TIMER BAR ===== */
  #timer-bar {
    position: absolute;
    top: 0;
    left: 0;
    height: 8px;
    background: linear-gradient(90deg, #ff4500, #ff8c00, #ffd700);
    box-shadow: 0 0 10px #ff4500;
    z-index: 300;
    width: 100%;
    transform-origin: left;
    transition: none;
  }

  /* ===== PHASE LABEL ===== */
  #phase-label {
    position: absolute;
    top: 20px;
    right: 20px;
    z-index: 300;
    font-size: clamp(0.8rem, 2.5vw, 1.3rem);
    color: rgba(255,255,255,0.7);
    text-shadow: 0 1px 4px rgba(0,0,0,0.8);
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* ===== FROZEN TIMER ===== */
  #timer-bar.frozen {
    background: linear-gradient(90deg, #00bfff, #87ceeb, #e0f4ff);
    box-shadow: 0 0 10px #00bfff;
  }

  /* ===== HIDDEN ===== */
  .hidden { display: none !important; }

  /* ===== START SCREEN ===== */
  #start-screen {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, #2d0a0a, #0d0520);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 999;
    text-align: center;
    padding: 2rem;
  }
  #start-screen h1 {
    font-size: clamp(2.5rem, 10vw, 7rem);
    color: #ff4500;
    text-shadow: 0 0 30px #ff4500, 0 0 60px #ff8c00, 0 4px 0 #8b0000;
    margin-bottom: 0.5rem;
    animation: titlePulse 2s ease-in-out infinite;
  }
  @keyframes titlePulse {
    0%,100% { transform: scale(1); text-shadow: 0 0 30px #ff4500, 0 0 60px #ff8c00, 0 4px 0 #8b0000; }
    50% { transform: scale(1.03); text-shadow: 0 0 50px #ff6600, 0 0 100px #ff8c00, 0 4px 0 #8b0000; }
  }
  #start-screen .subtitle {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: clamp(1rem, 3vw, 2rem);
    color: #ffd700;
    margin-bottom: 3rem;
    text-shadow: 0 2px 8px rgba(0,0,0,0.5);
  }
  #start-btn {
    font-family: 'Fredoka One', cursive;
    font-size: clamp(1.5rem, 5vw, 3rem);
    background: linear-gradient(135deg, #ff4500, #ff8c00);
    color: white;
    border: none;
    padding: 1rem 3rem;
    border-radius: 100px;
    cursor: pointer;
    box-shadow: 0 8px 30px rgba(255,69,0,0.5), 0 4px 0 #8b0000;
    transition: all 0.15s;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  #start-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(255,69,0,0.7), 0 4px 0 #8b0000;
  }
  #start-btn:active { transform: translateY(1px); box-shadow: 0 4px 20px rgba(255,69,0,0.5), 0 2px 0 #8b0000; }

  #options-btn {
    font-family: 'Fredoka One', cursive;
    font-size: clamp(1rem, 3vw, 1.6rem);
    background: transparent;
    color: rgba(255,200,100,0.8);
    border: 2px solid rgba(255,200,100,0.4);
    padding: 0.6rem 2rem;
    border-radius: 100px;
    cursor: pointer;
    margin-top: 1.2rem;
    letter-spacing: 2px;
    transition: all 0.15s;
  }
  #options-btn:hover {
    background: rgba(255,200,100,0.1);
    border-color: rgba(255,200,100,0.8);
    color: #ffd700;
  }

  /* ===== OPTIONS MODAL ===== */
  #options-modal {
    display: none;
    position: absolute;
    inset: 0;
    z-index: 1100;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(6px);
  }
  #options-modal.open { display: flex; }

  #options-box {
    background: linear-gradient(160deg, #1e0a00, #2a0d2e);
    border: 2px solid rgba(255,120,30,0.4);
    border-radius: 24px;
    padding: 2rem 2.5rem;
    width: min(90vw, 480px);
    box-shadow: 0 0 60px rgba(255,69,0,0.3);
  }
  #options-box h2 {
    font-size: clamp(1.5rem, 5vw, 2.2rem);
    color: #ff8c00;
    text-shadow: 0 0 20px #ff4500;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .opt-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.1rem;
    gap: 1rem;
  }
  .opt-row label {
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: clamp(0.85rem, 2.5vw, 1.1rem);
    color: #ffd97d;
    flex: 1;
    line-height: 1.3;
  }
  .opt-row label span {
    display: block;
    font-size: 0.75em;
    color: rgba(255,200,100,0.5);
    font-weight: 400;
  }
  .opt-row input[type=number] {
    font-family: 'Fredoka One', cursive;
    font-size: clamp(1rem, 3vw, 1.4rem);
    width: 90px;
    background: rgba(255,255,255,0.07);
    border: 2px solid rgba(255,120,30,0.4);
    border-radius: 12px;
    color: #fff;
    text-align: center;
    padding: 0.4rem 0.5rem;
    outline: none;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
  }
  .opt-row input[type=number]::-webkit-inner-spin-button,
  .opt-row input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; }
  .opt-row input[type=number]:focus { border-color: #ff8c00; }

  .opt-unit {
    font-family: 'Nunito', sans-serif;
    font-size: 0.85rem;
    color: rgba(255,200,100,0.5);
    width: 30px;
  }

  .opt-divider {
    border: none;
    border-top: 1px solid rgba(255,120,30,0.2);
    margin: 1.2rem 0;
  }

  #options-save {
    font-family: 'Fredoka One', cursive;
    font-size: clamp(1rem, 3vw, 1.5rem);
    background: linear-gradient(135deg, #ff4500, #ff8c00);
    color: white;
    border: none;
    padding: 0.7rem 2.5rem;
    border-radius: 100px;
    cursor: pointer;
    width: 100%;
    margin-top: 0.5rem;
    box-shadow: 0 6px 20px rgba(255,69,0,0.4), 0 3px 0 #8b0000;
    transition: all 0.15s;
    letter-spacing: 2px;
  }
  #options-save:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(255,69,0,0.6), 0 3px 0 #8b0000; }
  #options-save:active { transform: translateY(1px); }

  .opt-file-row {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.1rem;
  }
  .opt-file-row label {
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: clamp(0.85rem, 2.5vw, 1.1rem);
    color: #ffd97d;
    line-height: 1.3;
  }
  .opt-file-row label span {
    display: block;
    font-size: 0.75em;
    color: rgba(255,200,100,0.5);
    font-weight: 400;
  }
  .file-pick-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .file-pick-btn {
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    background: rgba(255,255,255,0.07);
    border: 2px solid rgba(255,120,30,0.4);
    border-radius: 10px;
    color: #ffd97d;
    padding: 0.4rem 0.9rem;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .file-pick-btn:hover { border-color: #ff8c00; background: rgba(255,120,30,0.15); }
  .file-name {
    font-family: 'Nunito', sans-serif;
    font-size: 0.78rem;
    color: rgba(255,200,100,0.55);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
  }
  .file-name.loaded { color: #7dffb0; }

  .emoji-row {
    font-size: clamp(2rem, 6vw, 4rem);
    margin-bottom: 1.5rem;
    animation: emojiFloat 3s ease-in-out infinite;
  }
  @keyframes emojiFloat {
    0%,100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  /* Screen flash */
  #flash {
    position: absolute;
    inset: 0;
    z-index: 500;
    opacity: 0;
    pointer-events: none;
  }
</style>
</head>
<body>
<div id="app">
  <!-- BG -->
  <div id="bg"></div>

  <!-- Start screen -->
  <div id="start-screen">
    <div class="emoji-row">🌋🔥💥</div>
    <h1>Chão é Lava!</h1>
    <p class="subtitle">Nina e Luke estão prontos?</p>
    <button id="start-btn" onclick="startGame()">JOGAR! 🎮</button>
    <button id="options-btn" onclick="openOptions()">⚙️ Opções</button>
  </div>

  <!-- Options modal -->
  <div id="options-modal">
    <div id="options-box">
      <h2>⚙️ Configurar Tempos</h2>

      <div class="opt-row">
        <label>⏱️ Contagem inicial<span>antes do furacão</span></label>
        <input type="number" id="opt-contagem" min="3" max="60" value="10">
        <span class="opt-unit">seg</span>
      </div>

      <div class="opt-row">
        <label>🌀 Furacão<span>duração do vento</span></label>
        <input type="number" id="opt-furacao" min="5" max="120" value="30">
        <span class="opt-unit">seg</span>
      </div>

      <div class="opt-row">
        <label>⚠️ Aviso do vulcão<span>aparece no segundo...</span></label>
        <input type="number" id="opt-aviso" min="3" max="119" value="20">
        <span class="opt-unit">seg</span>
      </div>

      <hr class="opt-divider">

      <div class="opt-row">
        <label>🔥 Lava na tela<span>tempo com lava</span></label>
        <input type="number" id="opt-lava" min="1" max="30" value="5">
        <span class="opt-unit">min</span>
      </div>

      <div class="opt-row">
        <label>❄️ Congelando<span>tempo de gelo</span></label>
        <input type="number" id="opt-gelo" min="1" max="30" value="5">
        <span class="opt-unit">min</span>
      </div>

      <hr class="opt-divider">

      <div class="opt-file-row">
        <label>💥 Som da explosão<span>toca uma vez quando o vulcão explode</span></label>
        <div class="file-pick-row">
          <button class="file-pick-btn" onclick="document.getElementById('file-explosao').click()">📂 Escolher arquivo</button>
          <span class="file-name" id="nome-explosao">nenhum arquivo</span>
        </div>
        <input type="file" id="file-explosao" accept="audio/*" style="display:none" onchange="carregarAudio(this,'explosao')">
      </div>

      <div class="opt-file-row">
        <label>🔥 Som da lava<span>toca em loop enquanto a lava está na tela</span></label>
        <div class="file-pick-row">
          <button class="file-pick-btn" onclick="document.getElementById('file-lava').click()">📂 Escolher arquivo</button>
          <span class="file-name" id="nome-lava">nenhum arquivo</span>
        </div>
        <input type="file" id="file-lava" accept="audio/*" style="display:none" onchange="carregarAudio(this,'lava')">
      </div>

      <button id="options-save" onclick="saveOptions()">✅ Salvar</button>
    </div>
  </div>

  <!-- Stars -->
  <div class="stars" id="stars"></div>

  <!-- Hurricane layer -->
  <div id="hurricane-layer"></div>

  <!-- Warning message -->
  <div id="warning-msg">
    <div class="warning-icon">⚠️🌋⚠️</div>
    <div id="warning-text">Nina e Luke,<br>cuidado o vulcão<br>vai explodir!</div>
  </div>

  <!-- Volcano -->
  <div id="volcano-layer">
    <svg class="volcano-svg" viewBox="0 0 400 250" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Base -->
      <path d="M20 250 L150 80 L200 80 L250 80 L380 250 Z" fill="#4a2800"/>
